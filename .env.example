# 이 파일을 .env로 복사한 뒤 실제 값을 채우세요. (.env는 절대 커밋하지 말 것)
# cp .env.example .env

# Claude API (AI 위험도 평가)
ANTHROPIC_API_KEY=

# Google OAuth (SSO 로그인)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_CALLBACK_URL=

# 릴레이 서버
RELAY_PORT=443
SESSION_SECRET=

# 커넥터 등록 토큰 (릴레이·커넥터 양쪽에서 동일 값 사용)
CONNECTOR_TOKEN=
